<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#264eff" />
            <corners android:radius="20dp" />
            <stroke android:width="3dp" android:color="#7C4DFF" />
        </shape>
    </item>
    <item android:top="1.5dp" android:bottom="1.5dp" android:left="1.5dp" android:right="1.5dp">
        <shape android:shape="rectangle">
            <solid android:color="#264eff" />
            <corners android:radius="20dp" />
            <stroke android:width="1.5dp" android:color="#6A3AFF" />
        </shape>
    </item>
</layer-list>
